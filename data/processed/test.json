  {
    "text": "The display is beyond horrible.",
    "aspects": [
      {
        "term": "display",
        "polarity": 0,
        "start_idx": 4,
        "end_idx": 11
      }
    ]
  },
  {
    "text": "There are no gold key numbers too intall programs, you must use the serial numbers that it does not accept and then things are limited as far a working because they are only good for a short time.",
    "aspects": [
      {
        "term": "programs",
