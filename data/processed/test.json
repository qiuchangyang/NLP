        "start_idx": 42,
        "end_idx": 47
      }
    ]
  },
  {
    "text": "It did fairly well, other than it's poor performance, overheating and occational blue screen.",
    "aspects": [
      {
        "term": "performance",
        "polarity": 0,
        "start_idx": 41,
        "end_idx": 52
      }
    ]
  },
  {
